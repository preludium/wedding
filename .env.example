# Copy to .env.local for local development (gitignored).
# In production (GitHub Pages), these are supplied as GitHub Actions repo
# secrets and injected at build time - see .github/workflows/deploy.yml.
# Nothing here is committed; the site falls back to generic placeholder
# copy when a variable is unset, so `pnpm dev` works with no .env at all.

# Access PIN - guests must enter this before seeing the page. 4 digits,
# e.g. 1234. Leave unset to disable the gate entirely (e.g. local dev).
# Note: this only deters casual link-sharing/crawlers, it's not real access
# control - the PIN ships in the client bundle like everything else on a
# static site, so anyone inspecting it can read it out.
VITE_ACCESS_PIN=

# Couple & date
VITE_NAME_1=
VITE_NAME_2=
# ISO local datetime, e.g. 2025-04-11T15:00
VITE_WEDDING_DATE=

# Venue 1 - reception
VITE_VENUE_1_NAME=
VITE_VENUE_1_ADDRESS=
VITE_VENUE_1_DESC=

# Venue 2 - ceremony
VITE_VENUE_2_NAME=
VITE_VENUE_2_ADDRESS=
VITE_VENUE_2_DESC=

# RSVP - shown as "Prosimy o potwierdzenie przybycia do <date>"
VITE_RSVP_DATE=

# Contacts - shown on the "Kontakt" info card as "<NAME_1>: <CONTACT_1>" etc.
# (reuses VITE_NAME_1/VITE_NAME_2 above, only the phone number is new)
VITE_CONTACT_1=
VITE_CONTACT_2=

# Photo URLs - e.g. S3 object URLs with public-read on just these objects.
# Leave unset to use the local drag-and-drop placeholder instead.
VITE_IMG_COUPLE=
VITE_IMG_VENUE_1=
VITE_IMG_VENUE_2=
VITE_IMG_GAL1=
VITE_IMG_GAL2=
VITE_IMG_GAL3=
VITE_IMG_GAL4=
VITE_IMG_GAL5=
VITE_IMG_GAL6=
